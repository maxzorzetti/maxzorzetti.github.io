---
layout: base.njk
section: blog
title: Blog
---
{% for post in collections.post | reverse %}
<article>
  <header class="post-header">
    <p class="meta">{{ post.date | readableDate }}</p>
    <h1><a href="{{ post.url }}">{{ post.data.title }}</a></h1>
    {% if post.data.deck %}<p class="deck">{{ post.data.deck }}</p>{% endif %}
  </header>
  {{ post.templateContent | safe }}
</article>
{% endfor %}
